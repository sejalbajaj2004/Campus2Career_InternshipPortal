<script>
/* Reports page JavaScript functionality (replace existing script) */
document.addEventListener('DOMContentLoaded', function() {
    initializeReportForm();
    initScheduleModule();
});

// ------------------ Report form / preview (unchanged core behavior) ------------------
function initializeReportForm() {
    const reportForm = document.getElementById('reportForm');
    const dateRangeSelect = document.getElementById('dateRange');
    const customDateRange = document.getElementById('customDateRange');
    
    if (dateRangeSelect) {
        dateRangeSelect.addEventListener('change', function() {
            if (customDateRange) customDateRange.style.display = (this.value === 'custom') ? 'block' : 'none';
        });
    }
    
    if (reportForm) reportForm.addEventListener('submit', handleReportGeneration);
}

async function handleReportGeneration(e) {
    e.preventDefault();
    const formData = new FormData(e.target);
    const reportData = Object.fromEntries(formData.entries());

    try {
        showLoading(e.target);
        // Replace with real backend endpoint. For now we'll attempt a fetch and handle errors gracefully.
        const response = await fetch(`/api/reports/generate?${new URLSearchParams(reportData)}`);
        if (!response.ok) throw new Error("Failed to generate report");
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `report-${Date.now()}.${reportData.format || 'pdf'}`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        window.URL.revokeObjectURL(url);
        showAlert('Report downloaded successfully!', 'success');
    } catch (err) {
        console.error(err);
        showAlert('Error generating report.', 'error');
    } finally {
        hideLoading(e.target);
    }
}

function previewReport() {
    const formData = new FormData(document.getElementById('reportForm'));
    const reportType = formData.get('reportType');
    if (!reportType) return showAlert('Please select a report type.', 'warning');
    const previewContent = generatePreviewContent(reportType);
    const previewContainer = document.getElementById('reportPreviewContent');
    if (previewContainer) previewContainer.innerHTML = previewContent;
    const modal = document.getElementById('reportPreviewModal');
    if (modal) modal.style.display = 'block';
}

function generatePreviewContent(reportType) {
    return `
        <h4>Preview: ${escapeHtml(reportType)} Report</h4>
        <p>This is a live preview of the <strong>${escapeHtml(reportType)}</strong> report based on selected filters.</p>
        <p><em>Note:</em> This preview is simulated in the frontend. Replace with server content if needed.</p>
    `;
}

function viewReport(reportId) {
    const previewContainer = document.getElementById('reportPreviewContent');
    if (previewContainer) {
        previewContainer.innerHTML = `
            <h4>Preview for ${escapeHtml(reportId)}</h4>
            <p>This is a generated preview of the <strong>${escapeHtml(reportId)}</strong> report.</p>
        `;
    }
    const modal = document.getElementById('reportPreviewModal');
    if (modal) modal.style.display = 'block';
}

function downloadFromPreview() {
    const blob = new Blob(["Sample report content"], { type: "application/pdf" });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `preview-report-${Date.now()}.pdf`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    window.URL.revokeObjectURL(url);
    closeModal();
}

// ------------------ Modal close helpers ------------------
function closeModal() {
    const modal = document.getElementById('reportPreviewModal');
    if (modal) modal.style.display = 'none';
}

window.onclick = function(event) {
    const modal = document.getElementById('reportPreviewModal');
    if (event.target === modal) closeModal();
};

// ------------------ Utilities ------------------
function showAlert(msg, type = 'info') {
    // Keep simple for now; replace with custom toast if desired.
    alert(`${type.toUpperCase()}: ${msg}`);
}
function showLoading(form) { if (form) console.log("Loading..."); }
function hideLoading(form) { if (form) console.log("Done."); }
function escapeHtml(str) {
    if (!str && str !== '') return '';
    return String(str)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

// ------------------ Scheduling module with persistence & working edit/delete ------------------
const SCHEDULE_STORAGE_KEY = 'scheduledReports_v1';
let scheduledReports = []; // in-memory copy

function initScheduleModule() {
    loadSchedulesFromStorage();
    migrateStaticSchedules(); // read the two hard-coded schedule items (if present) into storage once
    renderSchedules();

    // Keep compatibility helpers (in case some template HTML still triggers these by name)
    window.editSchedule = function(identifier) {
        const s = findScheduleByIdentifier(identifier);
        if (!s) return showAlert('Schedule not found', 'error');
        openScheduleModal('edit', s.id);
    };
    window.deleteSchedule = function(identifier) {
        const s = findScheduleByIdentifier(identifier);
        if (!s) return showAlert('Schedule not found', 'error');
        deleteScheduleById(s.id);
    };
}

function genId() {
    return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2,9)}`;
}

function slugify(text = '') {
    return String(text).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

function loadSchedulesFromStorage() {
    try {
        const raw = localStorage.getItem(SCHEDULE_STORAGE_KEY);
        scheduledReports = raw ? JSON.parse(raw) : [];
    } catch (e) {
        console.warn('Could not read schedules from storage', e);
        scheduledReports = [];
    }
}

function saveSchedulesToStorage() {
    try {
        localStorage.setItem(SCHEDULE_STORAGE_KEY, JSON.stringify(scheduledReports));
    } catch (e) {
        console.warn('Could not save schedules', e);
    }
}

/* If there are static items rendered server-side (the sample two items),
   pick their content up into storage so that everything becomes editable/deletable
   and persists. This avoids leaving two "unmanaged" schedule rows in the page. */
function migrateStaticSchedules() {
    const list = document.querySelector('.schedule-list');
    if (!list) return;
    const staticItems = Array.from(list.querySelectorAll(':scope > .schedule-item'));
    if (!staticItems.length) return;

    let added = false;
    staticItems.forEach(el => {
        // skip if this element already has a data-id (we only migrate raw static rows)
        if (el.dataset && el.dataset.id) return;

        const nameEl = el.querySelector('h4');
        if (!nameEl) return;
        const name = nameEl.innerText.trim();
        const timeEl = el.querySelector('p');
        const time = timeEl ? timeEl.innerText.trim() : '';
        const recipientsEl = el.querySelector('.schedule-recipients');
        const recipients = recipientsEl ? recipientsEl.innerText.replace(/^To:\s*/i,'').trim() : '';

        // avoid duplicates (by slug + time)
        const slug = slugify(name);
        const exists = scheduledReports.some(s => slugify(s.name) === slug && s.time === time);
        if (!exists) {
            scheduledReports.push({
                id: genId(),
                name,
                time,
                recipients,
                active: true
            });
            added = true;
        }
    });

    if (added) saveSchedulesToStorage();
    // we will re-render below in initScheduleModule
}

/* Renders the schedule list from the scheduledReports array */
function renderSchedules() {
    const list = document.querySelector('.schedule-list');
    if (!list) {
        console.warn('No schedule-list found in DOM');
        return;
    }
    // clear and re-render
    list.innerHTML = '';
    scheduledReports.forEach(s => {
        const item = document.createElement('div');
        item.className = 'schedule-item';
        item.dataset.id = s.id;

        const info = document.createElement('div');
        info.className = 'schedule-info';
        const h4 = document.createElement('h4');
        h4.textContent = s.name;
        const p = document.createElement('p');
        p.textContent = s.time;
        const rec = document.createElement('span');
        rec.className = 'schedule-recipients';
        rec.textContent = 'To: ' + (s.recipients || '');
        info.appendChild(h4);
        info.appendChild(p);
        info.appendChild(rec);

        const status = document.createElement('div');
        status.className = 'schedule-status';
        const statusSpan = document.createElement('span');
        statusSpan.className = 'status-badge ' + (s.active ? 'success' : 'warning');
        statusSpan.textContent = s.active ? 'Active' : 'Paused';
        status.appendChild(statusSpan);

        const actions = document.createElement('div');
        actions.className = 'schedule-actions';

        const editBtn = document.createElement('button');
        editBtn.className = 'btn-secondary small';
        editBtn.type = 'button';
        editBtn.innerHTML = '<i class="fas fa-edit"></i> Edit';
        editBtn.addEventListener('click', () => openScheduleModal('edit', s.id));

        const delBtn = document.createElement('button');
        delBtn.className = 'btn-danger small';
        delBtn.type = 'button';
        delBtn.innerHTML = '<i class="fas fa-trash"></i> Delete';
        delBtn.addEventListener('click', () => deleteScheduleById(s.id));

        actions.appendChild(editBtn);
        actions.appendChild(delBtn);

        item.appendChild(info);
        item.appendChild(status);
        item.appendChild(actions);

        list.appendChild(item);
    });
}

/* find schedule by id or fallback to slug matching (keeps compatibility with legacy inline calls) */
function findScheduleByIdentifier(identifier) {
    if (!identifier) return null;
    // if it's an id we stored, find directly
    let s = scheduledReports.find(r => r.id === identifier);
    if (s) return s;
    // otherwise try match by slug or exact name
    const normalized = String(identifier).toLowerCase();
    s = scheduledReports.find(r => slugify(r.name) === slugify(normalized) || r.name.toLowerCase() === normalized);
    return s || null;
}

/* Open modal for add or edit */
function openScheduleModal(mode = 'add', id = null) {
    // if edit, find object
    const isEdit = mode === 'edit' && id;
    const schedule = isEdit ? scheduledReports.find(s => s.id === id) : null;

    // ensure only one modal exists at a time
    closeScheduleModal();

    const overlay = document.createElement('div');
    overlay.id = 'scheduleModal';
    overlay.className = 'modal';
    overlay.style.display = 'block';
    overlay.innerHTML = `
        <div class="modal-content" role="dialog" aria-modal="true">
            <div class="modal-header">
                <h3>${isEdit ? 'Edit Scheduled Report' : 'Schedule New Report'}</h3>
                <button class="modal-close" id="closeScheduleModalBtn">&times;</button>
            </div>
            <div class="modal-body">
                <form id="scheduleForm">
                    <div class="form-group">
                        <label>Report Name</label>
                        <input id="sched_name" type="text" name="name" required>
                    </div>
                    <div class="form-group">
                        <label>Schedule (human readable)</label>
                        <input id="sched_time" type="text" name="time" placeholder="e.g. Every Monday 9:00 AM" required>
                    </div>
                    <div class="form-group">
                        <label>Recipients (comma separated emails)</label>
                        <input id="sched_recipients" type="text" name="recipients" placeholder="hr@company.com, manager@company.com" required>
                    </div>
                    <div class="form-actions" style="margin-top:10px;">
                        <button type="submit" class="btn-primary">${isEdit ? 'Save Changes' : 'Save Schedule'}</button>
                        <button type="button" class="btn-secondary" id="cancelScheduleBtn">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    `;
    document.body.appendChild(overlay);

    // populate values if edit
    if (isEdit && schedule) {
        document.getElementById('sched_name').value = schedule.name;
        document.getElementById('sched_time').value = schedule.time;
        document.getElementById('sched_recipients').value = schedule.recipients || '';
    }

    // close handlers
    document.getElementById('closeScheduleModalBtn').addEventListener('click', closeScheduleModal);
    document.getElementById('cancelScheduleBtn').addEventListener('click', closeScheduleModal);

    overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeScheduleModal();
    });

    const form = document.getElementById('scheduleForm');
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        const data = {
            name: document.getElementById('sched_name').value.trim(),
            time: document.getElementById('sched_time').value.trim(),
            recipients: document.getElementById('sched_recipients').value.trim(),
            active: true
        };
        if (!data.name) return showAlert('Please provide a report name.', 'warning');

        if (isEdit && schedule) {
            // update
            schedule.name = data.name;
            schedule.time = data.time;
            schedule.recipients = data.recipients;
            saveSchedulesToStorage();
            renderSchedules();
            closeScheduleModal();
            showAlert(`Schedule "${data.name}" updated.`, 'success');
        } else {
            // add new
            const newSched = { id: genId(), ...data };
            scheduledReports.push(newSched);
            saveSchedulesToStorage();
            renderSchedules();
            closeScheduleModal();
            showAlert(`Scheduled report "${data.name}" added.`, 'success');
        }
    });
}

function closeScheduleModal() {
    const modal = document.getElementById('scheduleModal');
    if (modal) modal.remove();
}

/* delete by internal id */
function deleteScheduleById(id) {
    const idx = scheduledReports.findIndex(s => s.id === id);
    if (idx === -1) return showAlert('Schedule not found', 'error');
    const name = scheduledReports[idx].name;
    if (!confirm(`Delete schedule "${name}"?`)) return;
    scheduledReports.splice(idx, 1);
    saveSchedulesToStorage();
    renderSchedules();
    showAlert(`Schedule "${name}" deleted.`, 'success');
}
</script>


