<script>

function showAlert(message, type = 'info') {
    // basic toast
    const toast = document.createElement('div');
    toast.className = 'toast toast-' + type;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => {
        toast.classList.add('show');
    }, 10);
    setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

function showLoading(target) {
    // target = form element or document.body
    if (!target) target = document.body;
    let overlay = target.querySelector('.loading-overlay');
    if (!overlay) {
        overlay = document.createElement('div');
        overlay.className = 'loading-overlay';
        overlay.innerHTML = '<div class="spinner"></div>';
        overlay.style.position = target === document.body ? 'fixed' : 'absolute';
        overlay.style.top = 0;
        overlay.style.left = 0;
        overlay.style.right = 0;
        overlay.style.bottom = 0;
        overlay.style.display = 'flex';
        overlay.style.alignItems = 'center';
        overlay.style.justifyContent = 'center';
        overlay.style.background = 'rgba(255,255,255,0.6)';
        overlay.style.zIndex = 9999;
        target.appendChild(overlay);
    }
    overlay.style.display = 'flex';
}

function hideLoading(target) {
    if (!target) target = document.body;
    const overlay = target.querySelector('.loading-overlay');
    if (overlay) overlay.style.display = 'none';
}

/* nested setter utility for "a.b.c" paths */
function setNested(obj, path, value) {
    const keys = path.split('.');
    let cur = obj;
    for (let i = 0; i < keys.length; i++) {
        const k = keys[i];
        if (i === keys.length - 1) {
            cur[k] = value;
        } else {
            if (!cur[k] || typeof cur[k] !== 'object') cur[k] = {};
            cur = cur[k];
        }
    }
}

/* Convert form element into nested object (handles unchecked checkboxes too) */
function formToObject(form) {
    const obj = {};
    const elements = [...form.elements];
    elements.forEach(el => {
        if (!el.name) return;
        // ignore buttons
        if (el.disabled || el.type === 'button' || el.type === 'submit') return;

        const name = el.name;
        let value;

        if (el.type === 'checkbox') {
            value = !!el.checked;
            setNested(obj, name, value);
        } else if (el.type === 'radio') {
            if (el.checked) setNested(obj, name, el.value);
        } else {
            // for selects and text inputs
            value = el.value;
            setNested(obj, name, value);
        }
    });
    return obj;
}

/* Save (partial) settings to backend via PUT /api/settings
   data: object with partial settings (e.g. { company: {...} } or { integrations: { slack: true }})
   options.form - optional form element to show loading
*/
async function saveSettings(data, options = {}) {
    const form = options.form || document.body;
    try {
        showLoading(form);
        const res = await fetch('/api/settings', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        // expect JSON success response; tolerate either { success: true } or status 200
        const json = await res.json().catch(()=>null);
        if (res.ok && (!json || json.success === undefined || json.success === true)) {
            showAlert('Settings saved successfully!', 'success');
            // optionally refresh parts of the page if server returned updated settings
            return { ok: true, json };
        } else {
            console.error('Save settings response:', res.status, json);
            showAlert((json && json.message) ? json.message : 'Error saving settings. Please try again.', 'error');
            return { ok: false, json };
        }
    } catch (err) {
        console.error('Error saving settings:', err);
        showAlert('Error saving settings. Please try again.', 'error');
        return { ok: false, error: err };
    } finally {
        hideLoading(form);
    }
}


document.addEventListener('DOMContentLoaded', function() {
    // wire up forms
    ['companyForm','notificationForm','internshipDefaultsForm','preferencesForm'].forEach(id => {
        const f = document.getElementById(id);
        if (f) f.addEventListener('submit', handleFormSubmit);
    });

    // integration toggles
    document.querySelectorAll('.integration-card input[type="checkbox"]').forEach(chk => {
        chk.addEventListener('change', handleIntegrationToggle);
    });

    // configure buttons
    document.querySelectorAll('.integration-config-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const key = this.dataset.key;
            openIntegrationModal(key);
        });
    });

    // integration modal submit
    const integrationForm = document.getElementById('integrationConfigForm');
    if (integrationForm) integrationForm.addEventListener('submit', submitIntegrationConfig);

    // theme live preview (optional)
    const themeSelect = document.getElementById('theme');
    if (themeSelect) {
        themeSelect.addEventListener('change', () => {
            // apply a data attribute -- adjust your CSS to use [data-theme="dark"] etc.
            document.documentElement.setAttribute('data-theme', themeSelect.value);
        });
    }
});

/* -------------------------
   Form submit handler
   ------------------------- */
async function handleFormSubmit(event) {
    event.preventDefault();
    const form = event.target;
    const payload = formToObject(form);
    // Send partial object to saveSettings
    await saveSettings(payload, { form });
}

/* -------------------------
   Integration toggle handler
   ------------------------- */
async function handleIntegrationToggle(e) {
    const checkbox = e.target;
    const name = checkbox.name; // expecting "integrations.key"
    if (!name) return;
    const parts = name.split('.');
    if (parts.length !== 2) {
        showAlert('Invalid integration toggle name', 'error');
        return;
    }
    const key = parts[1];
    const value = checkbox.checked;
    const partial = { integrations: {} };
    partial.integrations[key] = value;
    // optimistically show small message
    showAlert(`${key} ${value ? 'enabled' : 'disabled'}`, 'info');
    await saveSettings(partial);
}

/* -------------------------
   Export / Backup / Reset
   ------------------------- */
async function exportData(format) {
    try {
        showLoading(document.body);
        const res = await fetch(`/api/analytics/export?format=${encodeURIComponent(format)}`);
        if (!res.ok) {
            showAlert('Error exporting data. Please try again.', 'error');
            return;
        }
        const blob = await res.blob();
        // try to parse filename from header
        const disp = res.headers.get('Content-Disposition') || '';
        let filename = `internship-data-export.${format}`;
        const match = disp.match(/filename\*=UTF-8''(.+)|filename="(.+?)"/);
        if (match) filename = decodeURIComponent(match[1] || match[2]);
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        showAlert(`Data exported successfully as ${format.toUpperCase()}!`, 'success');
    } catch (err) {
        console.error('Export error:', err);
        showAlert('Error exporting data. Please try again.', 'error');
    } finally {
        hideLoading(document.body);
    }
}

async function backupSettings() {
    try {
        showLoading(document.body);
        const res = await fetch('/api/settings');
        if (!res.ok) {
            showAlert('Error fetching settings for backup.', 'error');
            return;
        }
        const data = await res.json();
        const dataStr = JSON.stringify(data, null, 2);
        const blob = new Blob([dataStr], { type: 'application/json' });
        const filename = `settings-backup-${new Date().toISOString().split('T')[0]}.json`;
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        showAlert('Settings backup downloaded successfully!', 'success');
    } catch (err) {
        console.error('Backup error:', err);
        showAlert('Error creating backup. Please try again.', 'error');
    } finally {
        hideLoading(document.body);
    }
}

async function resetSettings() {
    if (!confirm('Are you sure you want to reset all settings to default values? This action cannot be undone.')) return;
    try {
        showLoading(document.body);
        const res = await fetch('/api/settings/reset', { method: 'POST' });
        const json = await res.json().catch(()=>null);
        if (res.ok && (!json || json.success === undefined || json.success === true)) {
            showAlert('Settings reset to defaults. Reloading...', 'success');
            setTimeout(()=>location.reload(), 800);
        } else {
            console.error('Reset response:', res.status, json);
            showAlert((json && json.message) ? json.message : 'Error resetting settings.', 'error');
        }
    } catch (err) {
        console.error('Reset error:', err);
        showAlert('Error resetting settings. Please try again.', 'error');
    } finally {
        hideLoading(document.body);
    }
}

/* -------------------------
   Integration configure modal
   ------------------------- */
function openIntegrationModal(key) {
    const modal = document.getElementById('integrationModal');
    const title = document.getElementById('integrationModalTitle');
    const form = document.getElementById('integrationConfigForm');
    const inputKey = document.getElementById('integrationKey');
    const clientId = document.getElementById('integrationClientId');
    const clientSecret = document.getElementById('integrationClientSecret');
    const webhook = document.getElementById('integrationWebhook');

    title.textContent = `Configure ${key}`;
    inputKey.value = key;
    clientId.value = '';
    clientSecret.value = '';
    webhook.value = '';
    modal.style.display = 'block';

    // load existing config (if any)
    fetch(`/api/integrations/${encodeURIComponent(key)}`)
        .then(r => {
            if (!r.ok) throw new Error('No config');
            return r.json();
        })
        .then(cfg => {
            if (cfg.clientId) clientId.value = cfg.clientId;
            if (cfg.clientSecret) clientSecret.value = cfg.clientSecret;
            if (cfg.webhookUrl) webhook.value = cfg.webhookUrl;
        })
        .catch(() => {
            // no existing config — leave blank
        });
}

function closeIntegrationModal() {
    const modal = document.getElementById('integrationModal');
    if (modal) modal.style.display = 'none';
}

async function submitIntegrationConfig(e) {
    e.preventDefault();
    const form = e.target;
    const key = document.getElementById('integrationKey').value;
    const payload = {
        clientId: document.getElementById('integrationClientId').value,
        clientSecret: document.getElementById('integrationClientSecret').value,
        webhookUrl: document.getElementById('integrationWebhook').value
    };

    try {
        showLoading(document.getElementById('integrationModal'));
        const res = await fetch(`/api/integrations/${encodeURIComponent(key)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const json = await res.json().catch(()=>null);
        if (res.ok && (!json || json.success === undefined || json.success === true)) {
            showAlert(`${key} configured successfully.`, 'success');
            closeIntegrationModal();
        } else {
            console.error('Integration save failed', res.status, json);
            showAlert((json && json.message) ? json.message : 'Failed to save integration config.', 'error');
        }
    } catch (err) {
        console.error('Integration save error', err);
        showAlert('Error saving integration config. Please try again.', 'error');
    } finally {
        hideLoading(document.getElementById('integrationModal'));
    }
}

