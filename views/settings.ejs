<%- include('partials/header') %>

<div class="main-container">
    <%- include('partials/sidebar', { page: 'settings' }) %>
    
    <main class="main-content">
        <div class="page-header">
            <h1>Settings</h1>
            <p>Manage your company profile and system preferences</p>
        </div>

        <div class="settings-container">
            <!-- Company Information Section -->
            <div class="settings-section">
                <div class="section-header">
                    <h2><i class="fas fa-building"></i> Company Information</h2>
                    <p>Update your company profile and contact details</p>
                </div>
                
                <form id="companyForm" class="settings-form">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="companyName">Company Name *</label>
                            <input type="text" id="companyName" name="company.name" value="<%= settings.company?.name || '' %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="companyWebsite">Website</label>
                            <input type="url" id="companyWebsite" name="company.website" value="<%= settings.company?.website || '' %>">
                        </div>
                        
                        <div class="form-group">
                            <label for="companyEmail">HR Email *</label>
                            <input type="email" id="companyEmail" name="company.email" value="<%= settings.company?.email || '' %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="companyPhone">Phone Number</label>
                            <input type="tel" id="companyPhone" name="company.phone" value="<%= settings.company?.phone || '' %>">
                        </div>
                    </div>
                    
                    <div class="form-group full-width">
                        <label for="companyDescription">Company Description</label>
                        <textarea id="companyDescription" name="company.description" rows="4" placeholder="Brief description of your company..."><%= settings.company?.description || '' %></textarea>
                    </div>
                    
                    <div class="form-group full-width">
                        <label for="companyAddress">Address</label>
                        <textarea id="companyAddress" name="company.address" rows="2" placeholder="Company address..."><%= settings.company?.address || '' %></textarea>
                    </div>
                    
                    <div class="form-actions">
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Save Company Info
                        </button>
                    </div>
                </form>
            </div>

            <!-- Integrations -->
            <div class="settings-section" id="background4">
                <div class="section-header">
                    <h1><i class="fas fa-plug"></i> Integrations</h1>
                    <h3>Connect with external tools and services</h3>
                </div>
                
                <div class="integrations-grid">
                    <% const integrations = [
                        { key: 'googleWorkspace', icon: 'fab fa-google', name: 'Google Workspace', desc: 'Sync with Gmail and Google Calendar' },
                        { key: 'microsoftOffice', icon: 'fab fa-microsoft', name: 'Microsoft Office 365', desc: 'Connect with Outlook and Teams' },
                        { key: 'slack', icon: 'fab fa-slack', name: 'Slack', desc: 'Send notifications to Slack channels' },
                        { key: 'teams', icon: 'fab fa-microsoft', name: 'Microsoft Teams', desc: 'Collaborate through Teams integration' }
                    ]; %>
                    
                    <% integrations.forEach(intg => { %>
                        <div class="integration-card">
                            <div class="integration-header">
                                <div class="integration-icon">
                                    <i class="<%= intg.icon %>"></i>
                                </div>
                                <div class="integration-info">
                                    <h4><%= intg.name %></h4>
                                    <p><%= intg.desc %></p>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" name="integrations.<%= intg.key %>" <%= settings.integrations?.[intg.key] ? 'checked' : '' %>>
                                    <span class="slider"></span>
                                </label>
                            </div>
                            <div class="integration-actions">
                                <!-- configure button wired to JS -->
                                <button type="button" class="btn-secondary small integration-config-btn" data-key="<%= intg.key %>">Configure</button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Data Management -->
            <div class="settings-section">
                <div class="section-header">
                    <h2><i class="fas fa-database"></i> Data Management</h2>
                    <p>Export, backup, and manage your data</p>
                </div>
                
                <div class="data-actions">
                    <div class="action-card">
                        <div class="action-info">
                            <h4>Export Data</h4>
                            <p>Download all your internship and application data</p>
                        </div>
                        <div class="action-buttons">
                            <button class="btn-secondary" onclick="exportData('json')">
                                <i class="fas fa-file-code"></i> JSON
                            </button>
                            <button class="btn-secondary" onclick="exportData('csv')">
                                <i class="fas fa-file-csv"></i> CSV
                            </button>
                        </div>
                    </div>
                    
                    <div class="action-card">
                        <div class="action-info">
                            <h4>Backup Settings</h4>
                            <p>Create a backup of your current settings</p>
                        </div>
                        <div class="action-buttons">
                            <button class="btn-primary" onclick="backupSettings()">
                                <i class="fas fa-download"></i> Download Backup
                            </button>
                        </div>
                    </div>
                    
                    <div class="action-card danger">
                        <div class="action-info">
                            <h4>Reset Settings</h4>
                            <p>Reset all settings to default values</p>
                        </div>
                        <div class="action-buttons">
                            <button class="btn-danger" onclick="resetSettings()">
                                <i class="fas fa-undo"></i> Reset to Defaults
                            </button>
                        </div>
                    </div>
                </div>
            </div>

           
