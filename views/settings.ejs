function testNotification() {
    // In production you might call POST /api/notifications/test
    showAlert('Test notification triggered (frontend). Implement backend test route to actually send one.', 'info');
}
const themeSelect = document.getElementById('theme');
        if (themeSelect) {
            function applyTheme(value) {
                if (value === 'auto') {
                    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                    document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
                } else {
                    document.documentElement.setAttribute('data-theme', value);
                }
            }
            applyTheme(themeSelect.value);

            themeSelect.addEventListener('change', () => applyTheme(themeSelect.value));

            // auto-update if system theme changes
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                if (themeSelect.value === 'auto') applyTheme('auto');
            });
        }
