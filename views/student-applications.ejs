<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Applications - Campus2Career</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        /* ── Application Timeline ── */
        .app-timeline {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 18px 0 10px;
            position: relative;
            padding: 0 4px;
        }
        .app-timeline::before {
            content: '';
            position: absolute;
            top: 18px;
            left: 18px;
            right: 18px;
            height: 3px;
            background: #e5e7eb;
            z-index: 0;
        }
        .timeline-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            z-index: 1;
            min-width: 70px;
        }
        .timeline-dot {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            border: 3px solid #e5e7eb;
            background: #fff;
            color: #9ca3af;
            transition: all 0.3s;
        }
        .timeline-dot.done {
            background: #667eea;
            border-color: #667eea;
            color: #fff;
        }
        .timeline-dot.active {
            background: #fff;
            border-color: #667eea;
            color: #667eea;
            box-shadow: 0 0 0 4px rgba(102,126,234,0.15);
        }
        .timeline-dot.success {
            background: #10b981;
            border-color: #10b981;
            color: #fff;
        }
        .timeline-dot.rejected {
            background: #ef4444;
            border-color: #ef4444;
            color: #fff;
        }
        .timeline-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: #9ca3af;
            text-align: center;
            white-space: nowrap;
        }
        .timeline-label.done,
        .timeline-label.active {
            color: #667eea;
        }
        .timeline-label.success { color: #10b981; }
        .timeline-label.rejected { color: #ef4444; }

        /* Progress bar fill between steps */
        .timeline-line {
            flex: 1;
            height: 3px;
            background: #e5e7eb;
            margin-bottom: 22px;
            z-index: 0;
        }
        .timeline-line.filled {
            background: #667eea;
        }
        .timeline-line.success { background: #10b981; }
        .timeline-line.rejected { background: #ef4444; }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-container">
            <div class="logo">
                <h2><i class="fas fa-graduation-cap"></i> Student Portal</h2>
            </div>
            <nav class="nav">
                <ul>
                    <li><a href="/student-dashboard"><i class="fas fa-home"></i> <span>Dashboard</span></a></li>
                    <li><a href="/student-internships"><i class="fas fa-briefcase"></i> <span>Browse Jobs</span></a></li>
                    <li><a href="/student-applications" class="active"><i class="fas fa-file-alt"></i> <span>My Applications</span></a></li>
                    <li><a href="/student-profile"><i class="fas fa-user"></i> <span>Profile</span></a></li>
                </ul>
            </nav>
            <div class="user-profile">
                <div class="profile-info">
                    <i class="fas fa-user-circle"></i>
                    <span><%= user.name %></span>
                </div>
                <form action="/logout" method="POST" style="display: inline;">
                    <button type="submit" class="btn-secondary small">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </button>
                </form>
            </div>
        </div>
    </header>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-content">
                <div class="sidebar-section">
                    <h3>Navigation</h3>
                    <ul class="sidebar-menu">
                        <li><a href="/student-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/student-internships"><i class="fas fa-search"></i> Find Internships</a></li>
                        <li><a href="/student-applications" class="active"><i class="fas fa-file-alt"></i> My Applications</a></li>
                        <li><a href="/student-profile"><i class="fas fa-user-edit"></i> Edit Profile</a></li>
                        <li><a href="/blogs"><i class="fas fa-lightbulb"></i> Tech Blogs</a></li>
                        <li><a href="/news"><i class="fas fa-newspaper"></i> Latest News</a></li>
                    </ul>
                </div>

                <div class="sidebar-section">
                    <h3>Application Stats</h3>
                    <div class="quick-stats">
                        <div class="quick-stat">
                            <span class="stat-label">Total</span>
                            <span class="stat-number"><%= applications.length %></span>
                        </div>
                        <div class="quick-stat">
                            <span class="stat-label">Pending</span>
                            <span class="stat-number"><%= applications.filter(app => app.status === 'pending').length %></span>
                        </div>
                        <div class="quick-stat">
                            <span class="stat-label">Shortlisted</span>
                            <span class="stat-number"><%= applications.filter(app => app.status === 'shortlisted').length %></span>
                        </div>
                    </div>
                </div>

                <div class="help-card">
                    <h4>Application Tips</h4>
                    <p>Follow up on pending applications after a week.</p>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Page Header -->
            <div class="page-header">
                <h1><i class="fas fa-file-alt"></i> My Applications</h1>
                <p>Track the status of all your internship applications</p>
            </div>

            <!-- Filter Section -->
            <section class="filters-section">
                <div class="filter-group">
                    <select id="statusFilter">
                        <option value="">All Status</option>
                        <option value="pending">Pending</option>
                        <option value="shortlisted">Shortlisted</option>
                        <option value="rejected">Rejected</option>
                    </select>
                    <input type="text" id="searchApplications" placeholder="Search applications...">
                </div>
            </section>

            <!-- Applications Section -->
            <section class="content-section">
                <div class="section-header">
                    <h2><i class="fas fa-history"></i> Application History</h2>
                    <a href="/student-internships" class="btn-primary">
                        <i class="fas fa-plus"></i> Apply to More
                    </a>
                </div>

                <% if (applications.length > 0) { %>
                <div class="applicants-grid">
                    <% applications.forEach(app => { %>

                    <%
                        // Determine timeline state for each step
                        const isRejected  = app.status === 'rejected';
                        const isShortlist = app.status === 'shortlisted';
                        const isReviewed  = app.status === 'reviewed' || isShortlist || isRejected;
                        const isPending   = true; // always at least applied

                        // Step classes
                        const s1 = 'done';
                        const l1 = isReviewed || isRejected ? 'filled' : '';
                        const s2 = isReviewed ? (isRejected ? 'done' : 'done') : 'active';
                        const l2 = isShortlist ? 'success' : isRejected ? 'rejected' : '';
                        const s3 = isShortlist ? 'success' : isRejected ? 'rejected' : '';
                        const label3 = isShortlist ? 'Shortlisted' : isRejected ? 'Rejected' : 'Decision';
                        const dot3icon = isShortlist ? 'fa-star' : isRejected ? 'fa-times' : 'fa-question';
                    %>

                    <div class="applicant-card application-card" data-status="<%= app.status %>">
                        <div class="applicant-header">
                            <div class="applicant-info">
                                <h3><%= app.internshipTitle %></h3>
                                <p style="font-size:0.8rem; color:#667eea; font-weight:600; margin:2px 0;">
                                    <i class="fas fa-building"></i> <%= app.internshipCompany || 'Company' %>
                                </p>
                                <p><%= app.internshipDepartment %> • <%= app.internshipLocation || 'Location not specified' %></p>
                            </div>
                            <span class="status-badge <%= app.status %>"><%= app.status %></span>
                        </div>

                        <!-- ── Application Timeline ── -->
                        <div class="app-timeline">
                            <!-- Step 1: Applied -->
                            <div class="timeline-step">
                                <div class="timeline-dot done">
                                    <i class="fas fa-paper-plane"></i>
                                </div>
                                <span class="timeline-label done">Applied</span>
                            </div>

                            <div class="timeline-line <%= l1 %>"></div>

                            <!-- Step 2: Under Review -->
                            <div class="timeline-step">
                                <div class="timeline-dot <%= s2 %>">
                                    <i class="fas fa-search"></i>
                                </div>
                                <span class="timeline-label <%= s2 %>">Reviewing</span>
                            </div>

                            <div class="timeline-line <%= l2 %>"></div>

                            <!-- Step 3: Decision -->
                            <div class="timeline-step">
                                <div class="timeline-dot <%= s3 %>">
                                    <i class="fas <%= dot3icon %>"></i>
                                </div>
                                <span class="timeline-label <%= s3 %>"><%= label3 %></span>
                            </div>
                        </div>
                        <!-- ── End Timeline ── -->

                        <div class="application-details">
                            <div class="detail-row">
                                <i class="fas fa-calendar"></i>
                                <span>Applied on <%= new Date(app.appliedDate).toLocaleDateString() %></span>
                            </div>
                            <div class="detail-row">
                                <i class="fas fa-clock"></i>
                                <span>Duration: <%= app.internshipDuration || 'Not specified' %></span>
                            </div>
                            <% if (app.reviewedAt) { %>
                            <div class="detail-row">
                                <i class="fas fa-eye"></i>
                                <span>Reviewed on <%= new Date(app.reviewedAt).toLocaleDateString() %></span>
                            </div>
                            <% } %>
                        </div>

                        <% if (app.coverLetter) { %>
                        <div class="cover-letter-preview">
                            <h4>Your Cover Letter:</h4>
                            <p><%= app.coverLetter.substring(0, 150) %>...</p>
                        </div>
                        <% } %>

                        <div class="applicant-actions">
                            <a href="/student-internships/<%= app.internshipId?._id %>" class="btn-secondary small">
                                <i class="fas fa-eye"></i> View Job
                            </a>
                            <% if (app.status === 'shortlisted') { %>
                            <span class="btn-success small">
                                <i class="fas fa-star"></i> Congratulations!
                            </span>
                            <% } else if (app.status === 'pending') { %>
                            <span class="btn-warning small">
                                <i class="fas fa-hourglass-half"></i> Under Review
                            </span>
                            <% } %>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h3>No Applications Yet</h3>
                    <p>You haven't applied to any internships yet. Start browsing and applying to opportunities!</p>
                    <a href="/student-internships" class="btn-primary">
                        <i class="fas fa-search"></i> Browse Internships
                    </a>
                </div>
                <% } %>
            </section>
        </main>
    </div>

    <script>
        document.getElementById('statusFilter').addEventListener('change', function() {
            const selectedStatus = this.value.toLowerCase();
            const cards = document.querySelectorAll('.application-card');
            cards.forEach(card => {
                const cardStatus = card.dataset.status;
                card.style.display = (selectedStatus === '' || cardStatus === selectedStatus) ? 'block' : 'none';
            });
        });

        document.getElementById('searchApplications').addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            const cards = document.querySelectorAll('.application-card');
            cards.forEach(card => {
                const title = card.querySelector('h3').textContent.toLowerCase();
                const dept  = card.querySelector('.applicant-info p').textContent.toLowerCase();
                card.style.display = (searchTerm === '' || title.includes(searchTerm) || dept.includes(searchTerm)) ? 'block' : 'none';
            });
        });
    </script>
    <script src="/main.js"></script>
</body>
</html>

<%- include('partials/footer') %>
