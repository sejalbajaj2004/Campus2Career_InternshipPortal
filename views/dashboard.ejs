            <div class="internships-grid">
    <% if (internships && internships.length > 0) { %>
        <% internships.forEach(internship => { %>
            <div class="internship-card">

                <div class="internship-card-header">
                    <h3><%= internship.title %></h3>
                    <span class="status-badge <%= internship.status %>">
                        <%= internship.status %>
                    </span>
                </div>

                <div class="internship-card-body">
                    <div class="internship-meta">
                        <div class="internship-meta-item">
                            <i class="fas fa-building"></i>
                            <span><%= internship.department %></span>
                        </div>
                        <div class="internship-meta-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span><%= internship.location %></span>
                        </div>
                        <div class="internship-meta-item">
                            <i class="fas fa-clock"></i>
                            <span><%= internship.duration %></span>
                        </div>
                        <div class="internship-meta-item">
                            <i class="fas fa-rupee-sign"></i>
                            <span>₹<%= internship.stipend %>/month</span>
                        </div>
                    </div>
                </div>

                <div class="internship-card-footer">
                    <div class="internship-footer-info">
                        <span class="app-count">
                            <i class="fas fa-users"></i>
                            <%= internship.applicationsCount || 0 %> Applications
                        </span>
                        <span>
                            Posted: <%= new Date(internship.postedDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
                        </span>
                    </div>
                    <div class="internship-card-actions">
                        <button class="btn-edit" onclick="editInternship('<%= internship._id %>')">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <button class="btn-del" onclick="deleteInternship('<%= internship._id %>')">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>

            </div>
        <% }); %>
    <% } else { %>
        <div class="empty-state">
            <i class="fas fa-briefcase"></i>
            <h3>No internships posted yet</h3>
            <p>Start by posting your first internship opportunity</p>
            <a href="/post-internship" class="btn-primary">Post Internship</a>
        </div>
    <% } %>
</div>
        </div>
    </main>
</div>

<script>
    // ── Edit Internship ───────────────────────────────────────────────────────
    async function editInternship(id) {
        try {
            const r = await fetch(`/api/internships/${id}`);
            const data = await r.json();
            if (!data.success) { alert('Could not load internship.'); return; }
            const i = data.data;

            // Fill modal fields
            document.getElementById('editId').value          = i._id;
            document.getElementById('editTitle').value       = i.title       || '';
            document.getElementById('editDepartment').value  = i.department  || '';
            document.getElementById('editLocation').value    = i.location    || '';
            document.getElementById('editDuration').value    = i.duration    || '';
            document.getElementById('editStipend').value     = i.stipend     || '';
            document.getElementById('editType').value        = i.type        || 'Full-time';
            document.getElementById('editDescription').value = i.description || '';
            document.getElementById('editRequirements').value= i.requirements|| '';

            document.getElementById('editModal').style.display = 'flex';
        } catch { alert('Error loading internship.'); }
    }

    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
    }

    document.getElementById('editForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const id = document.getElementById('editId').value;
        const body = {
            title:       document.getElementById('editTitle').value,
            department:  document.getElementById('editDepartment').value,
            location:    document.getElementById('editLocation').value,
            duration:    document.getElementById('editDuration').value,
            stipend:     document.getElementById('editStipend').value,
            type:        document.getElementById('editType').value,
            description: document.getElementById('editDescription').value,
            requirements:document.getElementById('editRequirements').value,
        };
        try {
            const r = await fetch(`/api/internships/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await r.json();
            if (data.success) {
                closeEditModal();
                location.reload();
            } else {
                alert('Failed to update. Please try again.');
            }
        } catch { alert('Network error.'); }
    });

    // ── Delete Internship ─────────────────────────────────────────────────────
    async function deleteInternship(id) {
        if (!confirm('Are you sure you want to delete this internship?')) return;
        try {
            const r = await fetch(`/api/internships/${id}`, { method: 'DELETE' });
            const data = await r.json();
            if (data.success) location.reload();
            else alert('Failed to delete.');
        } catch { alert('Network error.'); }
    }
</script>

<!-- ── Edit Modal ─────────────────────────────────────────────────────────── -->
<div id="editModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5);
     z-index:2000; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; width:90%; max-width:640px;
                max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.2);">

        <!-- Modal Header -->
        <div style="padding:20px 24px; border-bottom:1px solid #e5e7eb;
                    display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:0; font-size:1.1rem; color:#111827;">
                <i class="fas fa-edit" style="color:#667eea;"></i> Edit Internship
            </h3>
            <button onclick="closeEditModal()"
                    style="background:none; border:none; font-size:1.4rem;
                           cursor:pointer; color:#9ca3af;">×</button>
        </div>

        <!-- Modal Form -->
        <form id="editForm" style="padding:24px;">
            <input type="hidden" id="editId">

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                <div>
                    <label style="font-size:0.85rem; font-weight:600; color:#374151;
                                  display:block; margin-bottom:6px;">Title *</label>
                    <input id="editTitle" type="text" required
                           style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                  border-radius:8px; font-size:0.88rem; box-sizing:border-box;">
                </div>
                <div>
                    <label style="font-size:0.85rem; font-weight:600; color:#374151;
                                  display:block; margin-bottom:6px;">Department *</label>
                    <select id="editDepartment" required
                            style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                   border-radius:8px; font-size:0.88rem; box-sizing:border-box;">
                        <option value="Technology">Technology</option>
                        <option value="Marketing">Marketing</option>
                        <option value="Finance">Finance</option>
                        <option value="Human Resources">Human Resources</option>
                        <option value="Operations">Operations</option>
                        <option value="Consulting">Consulting</option>
                    </select>
                </div>
                <div>
                    <label style="font-size:0.85rem; font-weight:600; color:#374151;
                                  display:block; margin-bottom:6px;">Location *</label>
                    <input id="editLocation" type="text" required
                           style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                  border-radius:8px; font-size:0.88rem; box-sizing:border-box;">
                </div>
                <div>
                    <label style="font-size:0.85rem; font-weight:600; color:#374151;
                                  display:block; margin-bottom:6px;">Duration *</label>
                    <select id="editDuration" required
                            style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                   border-radius:8px; font-size:0.88rem; box-sizing:border-box;">
                        <option value="2 months">2 months</option>
                        <option value="3 months">3 months</option>
                        <option value="4 months">4 months</option>
                        <option value="6 months">6 months</option>
                        <option value="12 months">12 months</option>
                    </select>
                </div>
                <div>
                    <label style="font-size:0.85rem; font-weight:600; color:#374151;
                                  display:block; margin-bottom:6px;">Stipend</label>
                    <input id="editStipend" type="text"
                           style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                  border-radius:8px; font-size:0.88rem; box-sizing:border-box;">
                </div>
                <div>
                    <label style="font-size:0.85rem; font-weight:600; color:#374151;
                                  display:block; margin-bottom:6px;">Type</label>
                    <select id="editType"
                            style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                   border-radius:8px; font-size:0.88rem; box-sizing:border-box;">
                        <option value="Full-time">Full-time</option>
                        <option value="Part-time">Part-time</option>
                        <option value="Remote">Remote</option>
                        <option value="Hybrid">Hybrid</option>
                    </select>
                </div>
            </div>

            <div style="margin-bottom:16px;">
                <label style="font-size:0.85rem; font-weight:600; color:#374151;
                              display:block; margin-bottom:6px;">Description *</label>
                <textarea id="editDescription" rows="4" required
                          style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                 border-radius:8px; font-size:0.88rem;
                                 box-sizing:border-box; resize:vertical;"></textarea>
            </div>

            <div style="margin-bottom:20px;">
                <label style="font-size:0.85rem; font-weight:600; color:#374151;
                              display:block; margin-bottom:6px;">Requirements</label>
                <textarea id="editRequirements" rows="3"
                          style="width:100%; padding:9px 12px; border:1px solid #d1d5db;
                                 border-radius:8px; font-size:0.88rem;
                                 box-sizing:border-box; resize:vertical;"></textarea>
            </div>

            <div style="display:flex; gap:10px; justify-content:flex-end;
                        padding-top:16px; border-top:1px solid #f3f4f6;">
                <button type="button" onclick="closeEditModal()"
                        style="padding:9px 20px; border-radius:8px; border:1px solid #d1d5db;
                               background:#f9fafb; color:#374151; font-weight:600;
                               cursor:pointer; font-size:0.88rem;">
                    Cancel
                </button>
                <button type="submit"
                        style="padding:9px 20px; border-radius:8px; border:none;
                               background:linear-gradient(135deg,#667eea,#764ba2);
                               color:#fff; font-weight:600; cursor:pointer; font-size:0.88rem;">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer') %>