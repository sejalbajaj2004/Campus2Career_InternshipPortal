<%- include('partials/header') %>

<style>
    .internships-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }

    .internship-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 0;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transition: box-shadow 0.2s, transform 0.2s;
        border-top: 4px solid #667eea;
    }
    .internship-card:hover {
        box-shadow: 0 8px 24px rgba(99,102,241,0.12);
        transform: translateY(-2px);
    }

    .internship-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 18px 20px 12px;
        border-bottom: 1px solid #f3f4f6;
    }
    .internship-card-header h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
    }

    .internship-card-body {
        padding: 14px 20px;
    }
    .internship-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 14px;
    }
    .internship-meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.84rem;
        color: #6b7280;
    }
    .internship-meta-item i {
        width: 16px;
        color: #667eea;
        font-size: 0.78rem;
    }

    .internship-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        background: #f9fafb;
        border-top: 1px solid #f3f4f6;
    }
    .internship-footer-info {
        font-size: 0.78rem;
        color: #9ca3af;
    }
    .internship-footer-info span {
        display: block;
    }
    .internship-footer-info .app-count {
        font-weight: 700;
        color: #6366f1;
        font-size: 0.88rem;
    }
    .internship-card-actions {
        display: flex;
        gap: 8px;
    }
    .internship-card-actions button {
        padding: 6px 16px;
        border-radius: 8px;
        border: none;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-edit {
        background: #ede9fe;
        color: #5b21b6;
    }
    .btn-edit:hover { background: #ddd6fe; }
    .btn-del {
        background: #fee2e2;
        color: #991b1b;
    }
    .btn-del:hover { background: #fecaca; }
</style>

