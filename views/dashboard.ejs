<%- include('partials/header') %>

<div class="main-container">
    <%- include('partials/sidebar', { page: 'dashboard' }) %>
    
    <main class="main-content">
        <div class="hero-section">
            <div class="hero-content">
                <h1>Welcome to Your Company Dashboard</h1>
                <p>Manage internship programs and connect with talented students</p>
            </div>
            <div class="hero-image">
                <img src="/images/company-dashboard.jpeg" alt="Modern office space" />
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fas fa-briefcase"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.totalInternships %></h3>
                    <p>Total Internships</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.totalApplications %></h3>
                    <p>Applications Received</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon orange">
                    <i class="fas fa-play-circle"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.activeInternships %></h3>
                    <p>Active Positions</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fas fa-star"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.shortlistedCandidates %></h3>
                    <p>Shortlisted</p>
                </div>
            </div>
        </div>

        <div class="content-section">
            <div class="section-header">
                <h2>Recent Internships</h2>
                <a href="/post-internship" class="btn-primary">Post New Internship</a>
            </div>
            
            <div class="internships-grid">
                <% if (internships && internships.length > 0) { %>
                    <% internships.forEach(internship => { %>
                        <div class="internship-card">
                            <div class="internship-header">
                                <h3><%= internship.title %></h3>
                                <span class="status-badge <%= internship.status %>"><%= internship.status %></span>
                            </div>
                            <div class="internship-details">
                                <p><i class="fas fa-building"></i> <%= internship.department %></p>
                                <p><i class="fas fa-map-marker-alt"></i> <%= internship.location %></p>
                                <p><i class="fas fa-clock"></i> <%= internship.duration %></p>
                                <p><i class="fas fa-dollar-sign"></i> <%= internship.stipend %></p>
                            </div>
                            <div class="internship-stats">
                                <span><%= internship.applicationsCount || 0 %> Applications</span>
                                <span>Posted: <%= internship.postedDate %></span>
                            </div>
                            <div class="internship-actions">
                                <button class="btn-secondary small" onclick="editInternship('<%= internship.id %>')">Edit</button>
                                <button class="btn-danger small" onclick="deleteInternship('<%= internship.id %>')">Delete</button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-briefcase"></i>
                        <h3>No internships posted yet</h3>
                        <p>Start by posting your first internship opportunity</p>
                        <a href="/post-internship" class="btn-primary">Post Internship</a>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>