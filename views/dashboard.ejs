<%- include('partials/header') %>

<style>
    .internships-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }

    .internship-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 0;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transition: box-shadow 0.2s, transform 0.2s;
        border-top: 4px solid #667eea;
    }
    .internship-card:hover {
        box-shadow: 0 8px 24px rgba(99,102,241,0.12);
        transform: translateY(-2px);
    }

    .internship-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 18px 20px 12px;
        border-bottom: 1px solid #f3f4f6;
    }
    .internship-card-header h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
    }

    .internship-card-body {
        padding: 14px 20px;
    }
    .internship-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 14px;
    }
    .internship-meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.84rem;
        color: #6b7280;
    }
    .internship-meta-item i {
        width: 16px;
        color: #667eea;
        font-size: 0.78rem;
    }

    .internship-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        background: #f9fafb;
        border-top: 1px solid #f3f4f6;
    }
    .internship-footer-info {
        font-size: 0.78rem;
        color: #9ca3af;
    }
    .internship-footer-info span {
        display: block;
    }
    .internship-footer-info .app-count {
        font-weight: 700;
        color: #6366f1;
        font-size: 0.88rem;
    }
    .internship-card-actions {
        display: flex;
        gap: 8px;
    }
    .internship-card-actions button {
        padding: 6px 16px;
        border-radius: 8px;
        border: none;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-edit {
        background: #ede9fe;
        color: #5b21b6;
    }
    .btn-edit:hover { background: #ddd6fe; }
    .btn-del {
        background: #fee2e2;
        color: #991b1b;
    }
    .btn-del:hover { background: #fecaca; }

    /* ── Edit Modal Styles ── */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 2000;
        align-items: center;
        justify-content: center;
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
        background: #fff;
        border-radius: 16px;
        width: 90%;
        max-width: 640px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }
    .modal-header {
        padding: 20px 24px;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .modal-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #111827;
    }
    .modal-close {
        background: none;
        border: none;
        font-size: 1.4rem;
        cursor: pointer;
        color: #9ca3af;
        line-height: 1;
    }
    .modal-close:hover { color: #374151; }
    .modal-form { padding: 24px; }
    .modal-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
    }
    .modal-field label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }
    .modal-field input,
    .modal-field select,
    .modal-field textarea {
        width: 100%;
        padding: 9px 12px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 0.88rem;
        box-sizing: border-box;
        font-family: inherit;
        transition: border-color 0.2s;
    }
    .modal-field input:focus,
    .modal-field select:focus,
    .modal-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
    }
    .modal-field textarea { resize: vertical; }
    .modal-field.full { grid-column: 1 / -1; }
    .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        padding-top: 16px;
        border-top: 1px solid #f3f4f6;
    }
    .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 12px 20px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #fff;
        z-index: 9999;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s;
        pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.success { background: #10b981; }
    .toast.error   { background: #ef4444; }
</style>

<div class="main-container">
    <%- include('partials/sidebar', { page: 'dashboard' }) %>
    
    <main class="main-content">
        <div class="hero-section">
    <div class="hero-content">
        <p style="font-size:0.88rem; opacity:0.75; margin-bottom:8px; font-weight:500; letter-spacing:0.05em; text-transform:uppercase;">
            <%= new Date().getHours() < 12 ? '🌅 Good Morning' : new Date().getHours() < 17 ? '☀️ Good Afternoon' : '🌙 Good Evening' %>
        </p>
        <h1>Welcome, <%= user.name %>!</h1>
        <p style="opacity:0.85; margin-bottom:6px;white-space:nowrap;">
            Manage internship programs and connect with talented students
        </p>
    </div>
    <div class="hero-image">
        <img src="/images/company-dashboard.jpeg" alt="Modern office space" />
    </div>
</div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-briefcase"></i></div>
                <div class="stat-info">
                    <h3><%= stats.totalInternships %></h3>
                    <p>Total Internships</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-users"></i></div>
                <div class="stat-info">
                    <h3><%= stats.totalApplications %></h3>
                    <p>Applications Received</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange"><i class="fas fa-play-circle"></i></div>
                <div class="stat-info">
                    <h3><%= stats.activeInternships %></h3>
                    <p>Active Positions</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple"><i class="fas fa-star"></i></div>
                <div class="stat-info">
                    <h3><%= stats.shortlistedCandidates %></h3>
                    <p>Shortlisted</p>
                </div>
            </div>
        </div>

        <div class="content-section">
            <div class="section-header">
                <h2>Recent Internships</h2>
                <a href="/post-internship" class="btn-primary">Post New Internship</a>
            </div>

            <div class="internships-grid">
                <% if (internships && internships.length > 0) { %>
                    <% internships.forEach(internship => { %>
                        <div class="internship-card">
                            <div class="internship-card-header">
                                <h3><%= internship.title %></h3>
                                <span class="status-badge <%= internship.status %>">
                                    <%= internship.status %>
                                </span>
                            </div>
                            <div class="internship-card-body">
                                <div class="internship-meta">
                                    <div class="internship-meta-item">
                                        <i class="fas fa-building"></i>
                                        <span><%= internship.department %></span>
                                    </div>
                                    <div class="internship-meta-item">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span><%= internship.location %></span>
                                    </div>
                                    <div class="internship-meta-item">
                                        <i class="fas fa-clock"></i>
                                        <span><%= internship.duration %></span>
                                    </div>
                                    <div class="internship-meta-item">
                                        <i class="fas fa-rupee-sign"></i>
                                        <span>₹<%= internship.stipend %>/month</span>
                                    </div>
                                </div>
                            </div>
                            <div class="internship-card-footer">
                                <div class="internship-footer-info">
                                    <span class="app-count">
                                        <i class="fas fa-users"></i>
                                        <%= internship.applicationsCount || 0 %> Applications
                                    </span>
                                    <span>
                                        Posted: <%= new Date(internship.postedDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
                                    </span>
                                </div>
                                <div class="internship-card-actions">
                                    <button class="btn-edit" onclick="openEditModal('<%= internship._id %>')">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn-del" onclick="deleteInternship('<%= internship._id %>')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-briefcase"></i>
                        <h3>No internships posted yet</h3>
                        <p>Start by posting your first internship opportunity</p>
                        <a href="/post-internship" class="btn-primary">Post Internship</a>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

<!-- ── Toast Notification ─────────────────────────────────────────────────── -->
<div id="toast" class="toast"></div>

<!-- ── Edit Modal ─────────────────────────────────────────────────────────── -->
<div id="editModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fas fa-edit" style="color:#667eea;"></i> Edit Internship</h3>
            <button class="modal-close" onclick="closeEditModal()">×</button>
        </div>
        <form id="editForm" class="modal-form">
            <input type="hidden" id="editId">
            <div class="modal-form-grid">
                <div class="modal-field">
                    <label>Title *</label>
                    <input id="editTitle" type="text" required placeholder="e.g. Software Intern">
                </div>
                <div class="modal-field">
                    <label>Department *</label>
                    <select id="editDepartment" required>
                        <option value="Technology">Technology</option>
                        <option value="Marketing">Marketing</option>
                        <option value="Finance">Finance</option>
                        <option value="Human Resources">Human Resources</option>
                        <option value="Operations">Operations</option>
                        <option value="Consulting">Consulting</option>
                    </select>
                </div>
                <div class="modal-field">
                    <label>Location *</label>
                    <input id="editLocation" type="text" required placeholder="e.g. Delhi">
                </div>
                <div class="modal-field">
                    <label>Duration *</label>
                    <select id="editDuration" required>
                        <option value="2 months">2 months</option>
                        <option value="3 months">3 months</option>
                        <option value="4 months">4 months</option>
                        <option value="6 months">6 months</option>
                        <option value="12 months">12 months</option>
                    </select>
                </div>
                <div class="modal-field">
                    <label>Stipend</label>
                    <input id="editStipend" type="text" placeholder="e.g. 15000">
                </div>
                <div class="modal-field">
                    <label>Type</label>
                    <select id="editType">
                        <option value="Full-time">Full-time</option>
                        <option value="Part-time">Part-time</option>
                        <option value="Remote">Remote</option>
                        <option value="Hybrid">Hybrid</option>
                    </select>
                </div>
                <div class="modal-field full">
                    <label>Description *</label>
                    <textarea id="editDescription" rows="4" required placeholder="Describe the internship role..."></textarea>
                </div>
                <div class="modal-field full">
                    <label>Requirements</label>
                    <textarea id="editRequirements" rows="3" placeholder="e.g. React, Node.js, communication skills..."></textarea>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" onclick="closeEditModal()"
                        style="padding:9px 20px;border-radius:8px;border:1px solid #d1d5db;
                               background:#f9fafb;color:#374151;font-weight:600;cursor:pointer;font-size:0.88rem;">
                    Cancel
                </button>
                <button type="submit" id="saveBtn"
                        style="padding:9px 20px;border-radius:8px;border:none;
                               background:linear-gradient(135deg,#667eea,#764ba2);
                               color:#fff;font-weight:600;cursor:pointer;font-size:0.88rem;">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // ── Toast helper ──────────────────────────────────────────────────────────
    function showToast(msg, type = 'success') {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.className = `toast ${type} show`;
        setTimeout(() => { t.className = 'toast'; }, 3000);
    }

    // ── Open Edit Modal ───────────────────────────────────────────────────────
    async function openEditModal(id) {
        try {
            const r    = await fetch(`/api/internships/${id}`, { credentials: 'include' });
            const data = await r.json();

            if (!data.success) {
                showToast('Could not load internship data.', 'error');
                return;
            }

            const i = data.data;

            document.getElementById('editId').value          = i._id;
            document.getElementById('editTitle').value       = i.title        || '';
            document.getElementById('editLocation').value    = i.location     || '';
            document.getElementById('editStipend').value     = i.stipend      || '';
            document.getElementById('editDescription').value = i.description  || '';

            // Requirements: could be array or string
            const req = Array.isArray(i.requirements)
                ? i.requirements.join(', ')
                : (i.requirements || '');
            document.getElementById('editRequirements').value = req;

            // Set select values properly
            setSelectValue('editDepartment', i.department);
            setSelectValue('editDuration',   i.duration);
            setSelectValue('editType',       i.type || 'Full-time');

            document.getElementById('editModal').classList.add('open');
        } catch (err) {
            console.error('openEditModal error:', err);
            showToast('Network error — could not load internship.', 'error');
        }
    }

    function setSelectValue(id, value) {
        const sel = document.getElementById(id);
        for (let opt of sel.options) {
            if (opt.value === value) { opt.selected = true; break; }
        }
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.remove('open');
    }

    // Close modal when clicking backdrop
    document.getElementById('editModal').addEventListener('click', function(e) {
        if (e.target === this) closeEditModal();
    });

    // ── Save Edit ─────────────────────────────────────────────────────────────
    document.getElementById('editForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const id      = document.getElementById('editId').value;
        const saveBtn = document.getElementById('saveBtn');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

        const reqRaw = document.getElementById('editRequirements').value;
        const requirements = reqRaw
            ? reqRaw.split(',').map(s => s.trim()).filter(Boolean)
            : [];

        const body = {
            title:        document.getElementById('editTitle').value.trim(),
            department:   document.getElementById('editDepartment').value,
            location:     document.getElementById('editLocation').value.trim(),
            duration:     document.getElementById('editDuration').value,
            stipend:      document.getElementById('editStipend').value.trim(),
            type:         document.getElementById('editType').value,
            description:  document.getElementById('editDescription').value.trim(),
            requirements
        };

        try {
            const r = await fetch(`/api/internships/${id}`, {
                method:      'PUT',
                credentials: 'include',
                headers:     { 'Content-Type': 'application/json' },
                body:        JSON.stringify(body)
            });

            const data = await r.json();

            if (data.success) {
                closeEditModal();
                showToast('Internship updated successfully!', 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                showToast(data.error || 'Failed to update. Please try again.', 'error');
            }
        } catch (err) {
            console.error('Save error:', err);
            showToast('Network error — please try again.', 'error');
        } finally {
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Changes';
        }
    });

    // ── Delete Internship ─────────────────────────────────────────────────────
    async function deleteInternship(id) {
        if (!confirm('Are you sure you want to delete this internship? This cannot be undone.')) return;
        try {
            const r    = await fetch(`/api/internships/${id}`, {
                method: 'DELETE',
                credentials: 'include'
            });
            const data = await r.json();
            if (data.success) {
                showToast('Internship deleted.', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(data.error || 'Failed to delete.', 'error');
            }
        } catch {
            showToast('Network error — please try again.', 'error');
        }
    }
</script>

<%- include('partials/footer') %>
