<!-- Replace JS functions -->
<script>
function toggleFaq(element) {
    const faqItem = element.parentElement;
    const answer = faqItem.querySelector('.faq-answer');
    const icon = element.querySelector('i');
    
    faqItem.classList.toggle('active');
    if (faqItem.classList.contains('active')) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
    } else {
        answer.style.maxHeight = '0px';
        icon.style.transform = 'rotate(0deg)';
    }
}
function goToContact() {
    document.getElementById("contact").scrollIntoView({ behavior: "smooth" });
}

// ✅ Live Chat (popup instead of broken /chat route)
// Open chat
function startLiveChat() {
    document.getElementById("chat-box").style.display = "block";
}

// Close chat
function closeChat() {
    document.getElementById("chat-box").style.display = "none";
}
function addMessage(sender, text) {
    const chatMessages = document.getElementById("chat-messages");
    const msgDiv = document.createElement("div");
    const time = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});

    msgDiv.style.margin = "6px 0";
    msgDiv.style.maxWidth = "80%";
    msgDiv.style.padding = "8px 12px";
    msgDiv.style.borderRadius = "12px";
    msgDiv.style.fontSize = "14px";
    msgDiv.style.wordWrap = "break-word";
    msgDiv.style.display = "inline-block";

    if (sender === "You") {
        msgDiv.textContent = `${text}  • ${time}`;
        msgDiv.style.background = "#4a3aff";
        msgDiv.style.color = "white";
        msgDiv.style.alignSelf = "flex-end";
        msgDiv.style.float = "right";
        msgDiv.style.clear = "both";
    } else {
        msgDiv.textContent = `${text}  • ${time}`;
        msgDiv.style.background = "#f1f1f1";
        msgDiv.style.color = "black";
        msgDiv.style.alignSelf = "flex-start";
        msgDiv.style.float = "left";
        msgDiv.style.clear = "both";
    }

    chatMessages.appendChild(msgDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
}
// Send message
function sendMessage() {
    const input = document.getElementById("chat-input");
    const msg = input.value.trim().toLowerCase();
    if (msg !== "") {
        addMessage("You", input.value);


        // Define fixed Q&A
        const answers = {
            "hello": "Hi there! 👋 How can I help you?",
            "how to register": "Go to the Register page, fill in your details, and click Submit.",
            "how to login": "Click on Login, enter your email and password, then press Login.",
            "forgot password": "Use the 'Forgot Password' option on the login page to reset it.",
            "contact": "You can email us at support@internhubpro.com or call +1-555-123-4567.",
            "tell me about internships": "You can check the official dashboard and learn about the recently posted internships."
        };

        // Pick answer
        let reply = answers[msg] || "Sorry, I don’t understand that yet. Please try another question.";
        setTimeout(() => addMessage("Bot", reply), 500);
         input.value = "";
    }
}
function callSupport() {
    window.location.href = "tel:+15551234567";
}

function openEmailForm() {
    window.location.href = "mailto:support@internhubpro.com?subject=Support%20Request&body=Please%20describe%20your%20issue";
}

// ✅ Play Tutorials in a new tab
function playTutorial(tutorialId) {
    const videos = {
        overview: "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
        creating: "https://www.youtube.com/watch?v=abcd1234",
        managing: "https://www.youtube.com/watch?v=efgh5678",
        analytics: "https://www.youtube.com/watch?v=ijkl9012"
    };
    const videoUrl = videos[tutorialId] || videos.overview;
    window.open(videoUrl, "_blank");   // opens video in new tab
}

// ✅ Smooth scroll for internal links
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
});
</script>




