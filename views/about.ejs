<%- include('partials/header') %>

<style>
    .about-page {
        padding: 40px 48px 60px;
    }

    /* Page Hero */
    .about-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 52px 48px;
        color: white;
        margin-bottom: 48px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        overflow: hidden;
        position: relative;
    }
    .about-hero::before {
        content: '';
        position: absolute;
        width: 300px; height: 300px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
        top: -80px; right: -60px;
    }
    .about-hero::after {
        content: '';
        position: absolute;
        width: 200px; height: 200px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
        bottom: -60px; left: 200px;
    }
    .about-hero-text h1 {
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 12px;
        line-height: 1.2;
    }
    .about-hero-text p {
        font-size: 1.1rem;
        opacity: 0.88;
        max-width: 520px;
        line-height: 1.7;
    }
    .about-hero-badge {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25);
        border-radius: 50px;
        padding: 10px 22px;
        font-size: 0.88rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
    }

    /* Nav Pills */
    .about-nav {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }
    .about-nav a {
        padding: 8px 20px;
        border-radius: 50px;
        background: #f1f5f9;
        color: #475569;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 600;
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
    }
    .about-nav a:hover, .about-nav a.active {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-color: transparent;
    }

    /* Sections */
    .about-section {
        margin-bottom: 56px;
        scroll-margin-top: 100px;
    }
    .section-title {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px;
    }
    .section-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }
    .icon-purple { background: linear-gradient(135deg, #667eea, #764ba2); }
    .icon-blue   { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
    .icon-green  { background: linear-gradient(135deg, #10b981, #047857); }
    .icon-orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .icon-red    { background: linear-gradient(135deg, #ef4444, #dc2626); }
    .icon-indigo { background: linear-gradient(135deg, #6366f1, #4338ca); }
    .icon-pink   { background: linear-gradient(135deg, #ec4899, #be185d); }
    .icon-teal   { background: linear-gradient(135deg, #14b8a6, #0f766e); }

    .section-title h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1e1b4b;
        margin: 0;
    }
    .section-title span {
        font-size: 0.82rem;
        color: #94a3b8;
        font-weight: 500;
        display: block;
        margin-top: 2px;
    }

    .section-card {
        background: white;
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
    }
    .section-card p {
        color: #4b5563;
        line-height: 1.85;
        font-size: 1rem;
        margin: 0 0 16px;
    }
    .section-card p:last-child { margin-bottom: 0; }

    /* Stats row */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 28px;
    }
    .stat-pill {
        background: linear-gradient(135deg, #f8faff, #f0f4ff);
        border: 1px solid #e0e7ff;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
    }
    .stat-pill .num {
        font-size: 1.8rem;
        font-weight: 800;
        color: #4338ca;
        display: block;
    }
    .stat-pill .lbl {
        font-size: 0.82rem;
        color: #6b7280;
        font-weight: 500;
        margin-top: 4px;
        display: block;
    }

    /* Values grid */
    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 16px;
        margin-top: 8px;
    }
    .value-card {
        background: #f8fafc;
        border: 1px solid #cdd3da;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all 0.2s;
    }
    .value-card:hover {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-color: transparent;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102,126,234,0.25);
    }
    .value-card:hover .value-icon { background: rgba(255,255,255,0.2); color: white; }
    .value-card:hover p { color: rgba(255,255,255,0.85); }
    .value-icon {
        width: 44px; height: 44px;
        background: #ede9fe;
        color: #7c3aed;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
        margin: 0 auto 12px;
        transition: all 0.2s;
    }
    .value-card h4 { font-size: 0.95rem; font-weight: 700; color: #1e293b; margin: 0 0 6px; }
    .value-card:hover h4 { color: white; }
    .value-card p { font-size: 0.90rem; color: #64748b; margin: 0; line-height: 1.5; }

    /* Contact cards */
    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 16px;
    }
    .contact-card {
        background: #f8fafc;
        border: 1px solid #d6dbe2;
        border-radius: 12px;
        padding: 22px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        transition: all 0.2s;
    }
    .contact-card:hover {
        border-color: #667eea;
        box-shadow: 0 4px 14px rgba(102,126,234,0.12);
    }
    .contact-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: white;
        font-size: 0.95rem;
        flex-shrink: 0;
    }
    .contact-info h4 { font-size: 0.95rem; font-weight: 700; color: #374151; margin: 0 0 4px; }
    .contact-info a, .contact-info span {
        font-size: 0.93rem; color: #6366f1; text-decoration: none;
        font-weight: 500; word-break: break-all;
    }
    .contact-info span { color: #4b5563; }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; gap: 12px; }
    .faq-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
    }
    .faq-q {
        padding: 16px 20px;
        font-weight: 600;
        font-size: 0.95rem;
        color: #1e293b;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        user-select: none;
    }
    .faq-q:hover { background: #f1f5f9; }
    .faq-q i { color: #667eea; font-size: 0.8rem; transition: transform 0.2s; }
    .faq-a {
        display: none;
        padding: 0 20px 16px;
        font-size: 0.88rem;
        color: #4b5563;
        line-height: 1.7;
        border-top: 1px solid #e2e8f0;
        padding-top: 14px;
    }
    .faq-item.open .faq-a { display: block; }
    .faq-item.open .faq-q i { transform: rotate(180deg); }

    /* Legal sections */
    .legal-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 16px;
    }
    .legal-card-header {
        padding: 18px 24px;
        background: linear-gradient(135deg, #f8faff, #f0f4ff);
        border-bottom: 1px solid #e0e7ff;
        font-weight: 700;
        color: #1e1b4b;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .legal-card-body {
        padding: 20px 24px;
        font-size: 0.93rem;
        color: #4b5563;
        line-height: 1.85;
    }

    /* Divider */
    .section-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
        margin: 48px 0;
    }
</style>

<div class="main-container">
    <%- include('partials/sidebar', { page: 'about' }) %>

    <main class="main-content">
        <div class="about-page">

            <!-- Hero -->
            <div class="about-hero">
                <div class="about-hero-text">
                    <div class="about-hero-badge">
                        <i class="fas fa-graduation-cap"></i> Campus2Career Platform
                    </div>
                    <h1>About Campus2Career</h1>
                    <p>We connect ambitious students with great companies, making internship discovery and hiring seamless, fair, and effective for everyone.</p>
                </div>
            </div>

            <!-- Quick nav pills -->
            <div class="about-nav">
                <a href="#about" class="active">About Us</a>
                <a href="#values">Our Values</a>
                <a href="#careers">Careers</a>
                <a href="#contact">Contact</a>
                <a href="#help">Help Center</a>
                <a href="#privacy">Privacy Policy</a>
                <a href="#terms">Terms of Service</a>
                <a href="#cookies">Cookie Policy</a>
            </div>

            <!-- ── About Us ── -->
            <section id="about" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-purple"><i class="fas fa-building"></i></div>
                    <div>
                        <h2>About Us</h2>
                        <span>Who we are and what we do</span>
                    </div>
                </div>
                <div class="section-card">
                    <p>Campus2Career was founded with a single mission: to make the internship hiring process better for everyone. We noticed that students struggled to find relevant opportunities, and companies struggled to reach the right talent — so we built a platform that solves both problems at once.</p>
                    <p>Our platform allows companies to post internship openings, review applications, shortlist candidates, and communicate with students — all in one place. Students can discover internships, apply with their profile, and track their application status in real time.</p>
                    <p>We believe every student deserves a shot at meaningful work experience, and every company deserves access to fresh, motivated talent. Campus2Career is built to make that happen.</p>
                    <div class="stats-row">
                        <div class="stat-pill">
                            <span class="num">500+</span>
                            <span class="lbl">Companies Onboarded</span>
                        </div>
                        <div class="stat-pill">
                            <span class="num">12,000+</span>
                            <span class="lbl">Students Registered</span>
                        </div>
                        <div class="stat-pill">
                            <span class="num">3,400+</span>
                            <span class="lbl">Internships Posted</span>
                        </div>
                    </div>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Our Values ── -->
            <section id="values" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-indigo"><i class="fas fa-heart"></i></div>
                    <div>
                        <h2>Our Values</h2>
                        <span>What we stand for</span>
                    </div>
                </div>
                <div class="values-grid">
                    <div class="value-card">
                        <div class="value-icon"><i class="fas fa-balance-scale"></i></div>
                        <h4>Fairness</h4>
                        <p>Every student gets an equal opportunity regardless of college or background.</p>
                    </div>
                    <div class="value-card">
                        <div class="value-icon"><i class="fas fa-shield-alt"></i></div>
                        <h4>Trust</h4>
                        <p>We verify companies and keep student data private and secure.</p>
                    </div>
                    <div class="value-card">
                        <div class="value-icon"><i class="fas fa-bolt"></i></div>
                        <h4>Speed</h4>
                        <p>Fast hiring, real-time notifications, and zero unnecessary steps.</p>
                    </div>
                    <div class="value-card">
                        <div class="value-icon"><i class="fas fa-handshake"></i></div>
                        <h4>Connection</h4>
                        <p>We build real bridges between students and companies, not just job boards.</p>
                    </div>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Careers ── -->
            <section id="careers" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-blue"><i class="fas fa-briefcase"></i></div>
                    <div>
                        <h2>Careers at Campus2Career</h2>
                        <span>Join our growing team</span>
                    </div>
                </div>
                <div class="section-card">
                    <p>We're a small, passionate team building something we genuinely care about. If you love education, technology, and creating products that make a real difference in people's lives — we'd love to hear from you.</p>
                    <p>We're currently looking for people in engineering, product design, and business development. We offer flexible work, competitive pay, and a culture that values deep work over meetings.</p>
                    <p>Send your resume and a short note about why you'd be a great fit to: <a href="mailto:careers@campus2career.com" style="color:#667eea;font-weight:600;">careers@campus2career.com</a></p>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Contact ── -->
            <section id="contact" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-green"><i class="fas fa-envelope"></i></div>
                    <div>
                        <h2>Contact Us</h2>
                        <span>We're here to help</span>
                    </div>
                </div>
                <div class="contact-grid">
                    <div class="contact-card">
                        <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                        <div class="contact-info">
                            <h4>General Enquiries</h4>
                            <a href="mailto:hello@campus2career.com">hello@campus2career.com</a>
                        </div>
                    </div>
                    <div class="contact-card">
                        <div class="contact-icon"><i class="fas fa-headset"></i></div>
                        <div class="contact-info">
                            <h4>Support</h4>
                            <a href="mailto:support@campus2career.com">support@campus2career.com</a>
                        </div>
                    </div>
                    <div class="contact-card">
                        <div class="contact-icon"><i class="fas fa-phone"></i></div>
                        <div class="contact-info">
                            <h4>Phone</h4>
                            <span>+91 98765 43210</span>
                        </div>
                    </div>
                    <div class="contact-card">
                        <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="contact-info">
                            <h4>Location</h4>
                            <span>Bengaluru, Karnataka, India</span>
                        </div>
                    </div>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Help Center ── -->
            <section id="help" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-orange"><i class="fas fa-life-ring"></i></div>
                    <div>
                        <h2>Help Center</h2>
                        <span>Frequently asked questions</span>
                    </div>
                </div>
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-q" onclick="toggleFaq(this)">
                            How do I post an internship as a company?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-a">Log in to your company dashboard, click "Post Internship" from the sidebar or top navigation, fill in the details like title, department, location, duration, stipend and description, then submit. Your internship will go live immediately.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-q" onclick="toggleFaq(this)">
                            How do students apply for internships?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-a">Students create an account, complete their profile with education, skills, and resume, then browse available internships and click "Apply". They can attach a cover letter and their profile is automatically shared with the company.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-q" onclick="toggleFaq(this)">
                            How do I shortlist or reject applicants?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-a">Go to "View Applicants" in your dashboard. You'll see all applicants for your internships. Use the status dropdown on each applicant to mark them as Shortlisted, Rejected, or keep them Pending. The student gets an email notification automatically.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-q" onclick="toggleFaq(this)">
                            I'm not receiving email notifications. What should I do?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-a">Check your spam/junk folder first. If emails aren't there, make sure your registered email address is correct in your profile settings. Still not working? Email us at support@campus2career.com and we'll look into it.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-q" onclick="toggleFaq(this)">
                            Can one company see internships posted by another company?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-a">No. Each company only sees its own internship postings and applicants. Our platform enforces strict data isolation — your data is private and visible only to you.</div>
                    </div>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Privacy Policy ── -->
            <section id="privacy" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-teal"><i class="fas fa-shield-alt"></i></div>
                    <div>
                        <h2>Privacy Policy</h2>
                        <span>How we handle your data</span>
                    </div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-database" style="color:#667eea;"></i> Data We Collect</div>
                    <div class="legal-card-body">We collect only the information needed to operate the platform — your name, email address, and profile details (for students: education, skills, resume; for companies: company name and contact info). We do not collect unnecessary personal data.</div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-lock" style="color:#667eea;"></i> How We Use Your Data</div>
                    <div class="legal-card-body">Your data is used solely to provide the Campus2Career service — matching students with companies, sending status notifications, and improving the platform. We never sell your data to advertisers or third parties under any circumstances.</div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-user-shield" style="color:#667eea;"></i> Your Rights</div>
                    <div class="legal-card-body">You can request access to your data, ask for corrections, or request deletion of your account at any time by emailing privacy@campus2career.com. We will respond within 7 business days.</div>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Terms of Service ── -->
            <section id="terms" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-red"><i class="fas fa-file-contract"></i></div>
                    <div>
                        <h2>Terms of Service</h2>
                        <span>Rules for using our platform</span>
                    </div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-building" style="color:#667eea;"></i> For Companies</div>
                    <div class="legal-card-body">Companies must post only genuine, legitimate internship opportunities. Misleading job descriptions, fake postings, or using the platform to collect student data for unrelated purposes is strictly prohibited and will result in immediate account suspension.</div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-user-graduate" style="color:#667eea;"></i> For Students</div>
                    <div class="legal-card-body">Students must provide accurate information in their profiles and applications. Submitting false credentials or plagiarised resumes is a violation of these terms. Multiple applications to the same role are not permitted.</div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-gavel" style="color:#667eea;"></i> Platform Rules</div>
                    <div class="legal-card-body">All users must treat each other with respect. Harassment, spam, or any form of abusive behaviour on the platform will not be tolerated. Campus2Career reserves the right to suspend or terminate accounts that violate these terms without prior notice.</div>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- ── Cookie Policy ── -->
            <section id="cookies" class="about-section">
                <div class="section-title">
                    <div class="section-icon icon-pink"><i class="fas fa-cookie-bite"></i></div>
                    <div>
                        <h2>Cookie Policy</h2>
                        <span>How we use cookies</span>
                    </div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-check-circle" style="color:#667eea;"></i> Essential Cookies Only</div>
                    <div class="legal-card-body">Campus2Career uses only essential, functional cookies — specifically a secure session cookie that keeps you logged in while you use the platform. We do not use advertising cookies, tracking pixels, or third-party analytics cookies of any kind.</div>
                </div>
                <div class="legal-card">
                    <div class="legal-card-header"><i class="fas fa-trash-alt" style="color:#667eea;"></i> Clearing Cookies</div>
                    <div class="legal-card-body">You can clear cookies at any time through your browser settings. Clearing your session cookie will log you out of the platform. No personal data is stored in cookies — cookies only contain a secure token used to authenticate your session.</div>
                </div>
            </section>

        </div>
    </main>
</div>

<script>
    function toggleFaq(el) {
        const item = el.parentElement;
        item.classList.toggle('open');
    }

    // Highlight active nav pill on scroll
    const sections = document.querySelectorAll('.about-section');
    const navLinks = document.querySelectorAll('.about-nav a');

    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(s => {
            if (window.scrollY >= s.offsetTop - 120) current = s.id;
        });
        navLinks.forEach(a => {
            a.classList.toggle('active', a.getAttribute('href') === '#' + current);
        });
    });
</script>

<%- include('partials/footer') %>