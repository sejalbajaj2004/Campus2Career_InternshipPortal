                    'rgb(102, 126, 234)',
                    'rgb(16, 185, 129)',
                    'rgb(245, 158, 11)',
                    'rgb(239, 68, 68)',
                    'rgb(139, 92, 246)',
                    'rgb(236, 72, 153)'
                ]
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'right'
                }
            }
        }
    });

    // Status breakdown chart
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    const statusData = <%= JSON.stringify(analytics.statusBreakdown) %>;
    
    statusChart = new Chart(statusCtx, {
        type: 'pie',
        data: {
            labels: ['Pending', 'Shortlisted', 'Rejected'],
