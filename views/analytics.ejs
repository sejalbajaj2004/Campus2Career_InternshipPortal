        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });
}

function initializeFilters() {
    // Time period filters
    const periodButtons = document.querySelectorAll('[data-period]');
    periodButtons.forEach(button => {
        button.addEventListener('click', function() {
            periodButtons.forEach(btn => btn.classList.remove('active'));
            this.classList.add('active');
            updateActivityData(this.dataset.period);
        });
    });

    // Trend metric selector
    const trendMetricSelect = document.getElementById('trendMetric');
    if (trendMetricSelect) {
        trendMetricSelect.addEventListener('change', updateTrendsChart);
    }

    // Search functionality
    const searchInput = document.getElementById('internshipSearch');
    if (searchInput) {
        searchInput.addEventListener('input', debounce(searchTable, 300));
    }
}

function updateTrendsChart() {
    const selectedMetric = document.getElementById('trendMetric').value;
    const datasets = trendsChart.data.datasets;

    switch (selectedMetric) {
        case 'internships':
            datasets[0].hidden = false;
            datasets[1].hidden = true;
            break;
        case 'applications':
            datasets[0].hidden = true;
            datasets[1].hidden = false;
            break;
        default:
            datasets[0].hidden = false;
            datasets[1].hidden = false;
    }

    trendsChart.update();
}

function toggleChartType(chartName) {
    if (chartName === 'department') {
        const currentType = departmentChart.config.type;
        const newType = currentType === 'doughnut' ? 'bar' : 'doughnut';
        
        departmentChart.destroy();
        const ctx = document.getElementById('departmentChart').getContext('2d');
        
        departmentChart = new Chart(ctx, {
            type: newType,
            data: departmentChart.data,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: newType === 'bar' ? 'top' : 'right'
                    }
                },
                scales: newType === 'bar' ? {
                    y: {
                        beginAtZero: true
                    }
                } : {}
            }
        });
    }
}

function updateActivityData(period) {
    // This would typically fetch new data based on the selected period
    showAlert(`Activity data updated for period: ${period}`, 'info');
}

function searchTable() {
    const searchTerm = document.getElementById('internshipSearch').value.toLowerCase();
    const tableRows = document.querySelectorAll('#internshipsTableBody tr');
    
    tableRows.forEach(row => {
        const text = row.textContent.toLowerCase();
        if (text.includes(searchTerm)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
}

async function refreshAnalytics() {
    try {
        showAlert('Refreshing analytics data...', 'info');
        
        const response = await fetch('/api/analytics/dashboard');
        const newData = await response.json();
        
        // Update metrics
        document.getElementById('totalInternships').textContent = newData.summary.totalInternships;
        document.getElementById('totalApplications').textContent = newData.summary.totalApplications;
        document.getElementById('activeInternships').textContent = newData.summary.activeInternships;
        document.getElementById('avgApplications').textContent = newData.summary.avgApplicationsPerInternship;
        
        // Update charts with new data
        trendsChart.data.datasets[0].data = newData.monthlyTrends.map(d => d.internships);
        trendsChart.data.datasets[1].data = newData.monthlyTrends.map(d => d.applications);
        trendsChart.update();
        
        // Update department chart
        departmentChart.data.labels = Object.keys(newData.departmentStats);
        departmentChart.data.datasets[0].data = Object.values(newData.departmentStats);
        departmentChart.update();
        
        // Update status chart
        statusChart.data.datasets[0].data = [
            newData.statusBreakdown.pending,
            newData.statusBreakdown.shortlisted,
            newData.statusBreakdown.rejected
        ];
        statusChart.update();
        
        showAlert('Analytics data refreshed successfully!', 'success');
    } catch (error) {
        console.error('Error refreshing analytics:', error);
        showAlert('Error refreshing analytics data.', 'error');
    }
}

async function exportReport() {
    try {
        const response = await fetch('/api/analytics/export?format=json');
        
        if (response.ok) {
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `analytics-report-${new Date().toISOString().split('T')[0]}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
            
            showAlert('Analytics report exported successfully!', 'success');
        } else {
            showAlert('Error exporting report.', 'error');
        }
    } catch (error) {
        console.error('Export error:', error);
        showAlert('Error exporting report.', 'error');
    }
}

function exportTable(tableType) {
    // This would export the specific table data as CSV
    showAlert(`${tableType} table export would be implemented here.`, 'info');
}

function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
        const later = () => {
            clearTimeout(timeout);
            func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
    };
}
